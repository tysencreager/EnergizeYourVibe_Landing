# Public Supabase config — safe to expose in client bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Stripe-hosted Payment Link.
# - Local / Cloudflare Preview: use the TEST-mode link (https://buy.stripe.com/test_...)
# - Cloudflare Production: use the LIVE-mode link
# If unset, the app falls back to the hardcoded live link in src/data/links.js.
VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/test_your-test-link

# --- Server-side only (functions/api/stripe-webhook.js) ---
# Set these in Cloudflare Pages → Settings → Environment variables.
# NEVER prefix these with VITE_ — that would leak them into the client bundle.

# Signing secret of the Stripe webhook endpoint (Stripe → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Service role key (Supabase → Settings → API). Bypasses RLS — server only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: enroll paying members into the MailerLite welcome drip
MAILERLITE_API_KEY=your-mailerlite-api-key
MAILERLITE_GROUP_ID=192368708907173146
